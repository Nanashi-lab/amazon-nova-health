# ─── AWS ───────────────────────────────────────────────────────────
# AWS credentials are loaded via the boto3 default credential chain:
#   1. ~/.aws/credentials  (set up with: aws configure)
#   2. AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY env vars
#   3. IAM instance role (if running on EC2/ECS)
#
# Required IAM policy: AmazonBedrockFullAccess (or access to these models):
#   - amazon.nova-2-lite-v1:0        (agent reasoning)
#   - amazon.nova-2-multimodal-embeddings-v1:0  (semantic search)
#   - amazon.nova-2-sonic-v1:0       (voice I/O)
#
# You do NOT need to set AWS keys here if you already ran `aws configure`.
AWS_REGION=us-east-1

# ─── JWT ───────────────────────────────────────────────────────────
# Secret used to sign login tokens. Change this for any non-local deployment.
JWT_SECRET=novahealth-dev-secret-2026

# ─── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://nova:nova@localhost:5432/novahealth
